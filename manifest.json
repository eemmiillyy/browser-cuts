{
  "manifest_version": 3,
  "name": "Browser Cuts",
  "version": "1.0.0",
  "description": "Browser cuts extension inspired by gordon matta clark.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fonts/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
